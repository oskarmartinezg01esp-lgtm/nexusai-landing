    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "1",
              "name": "replyText",
              "value": "=✅ *¡Cita confirmada!*\\n\\n📅 *Fecha:* {{ $('Parsear JSON de Cita').item.json.fecha }}\\n⏰ *Hora:* {{ $('Parsear JSON de Cita').item.json.hora }}\\n\\nTe hemos enviado una invitación a Google Calendar. Si necesitas cancelar o cambiar la cita, escríbenos aquí mismo.\\n\\n¡Hasta pronto! 🚀",
              "type": "string"
            },
            {
              "id": "2",
              "name": "phone",
