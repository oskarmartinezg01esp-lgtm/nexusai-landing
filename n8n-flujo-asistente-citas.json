        "options": {}
      },
      "id": "extract-data",
      "name": "Extraer Datos del Mensaje",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [680, 220]
    },
    {
      "parameters": {
        "model": "gpt-4o",
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "Eres el asistente virtual de NexusAI, una agencia digital especializada en Diseño Web SEO, Meta Ads y Automatización con IA.\n\nTU MISIÓN: Atender al cliente de forma amable y profesional. Puedes hacer dos cosas principales:\n1. Responder preguntas sobre los servicios de NexusAI.\n2. Agendar una cita/reunión con el equipo.\n\nSERVICIOS QUE OFRECEMOS:\n- Diseño Web Optimizado para SEO (desde 800€)\n- Campañas de Meta Ads con gestión mensual (desde 300€/mes)\n- Asistentes Virtuales con IA integrados en WhatsApp/Web (desde 500€)\n- Paquetes completos con descuento\n\nPARA AGENDAR UNA CITA necesitas recopilar:\n- Nombre del cliente\n- Fecha preferida (disponibilidad: lunes a viernes, 9:00-19:00, no fines de semana)\n- Hora preferida\n\nUna vez que tengas TODOS los datos, responde ÚNICAMENTE con este JSON (sin texto adicional):\n{\"accion\": \"agendar_cita\", \"nombre\": \"...\", \"fecha\": \"DD/MM/YYYY\", \"hora\": \"HH:MM\", \"confirmado\": true}\n\nSi el cliente NO quiere cita sino solo información, responde normalmente en texto.\n\nREGLAS IMPORTANTES:\n- Siempre en español, tono profesional pero cercano.\n- No inventes precios ni servicios que no se hayan listado.\n- Si el cliente pregunta algo que no sabes, dile que le pasarás con el equipo.\n- Respuestas cortas y directas (máximo 3 párrafos).\n- La fecha de hoy es {{ $now.toFormat('dd/MM/yyyy') }}."
            },
            {
              "role": "user",
              "content": "={{ $json.message }}"
            }
          ]
        },
        "options": {
          "temperature": 0.7,
          "maxTokens": 500
        }
      },
      "id": "openai-chat",
      "name": "GPT-4o — Procesar Mensaje",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.4,
      "position": [900, 220],
      "credentials": {
        "openAiApi": {
          "id": "REEMPLAZA_CON_ID_CREDENCIAL_OPENAI",
          "name": "OpenAI API"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": false },
          "conditions": [
            {
              "id": "check-json",
              "leftValue": "={{ $json.message.content }}",
              "rightValue": "\"accion\": \"agendar_cita\"",
              "operator": { "type": "string", "operation": "contains" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-cita",
      "name": "¿Quiere agendar cita?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1120, 220]
    },
    {
      "parameters": {
        "jsCode": "const raw = items[0].json.message.content.trim();\nlet citaData;\ntry {\n  // Extraer el JSON aunque venga con texto alrededor\n  const match = raw.match(/\\{[\\s\\S]*\\}/);\n  citaData = match ? JSON.parse(match[0]) : null;\n} catch(e) {\n  citaData = null;\n}\n\nif (!citaData || !citaData.confirmado) {\n  return [{ json: { error: 'JSON inválido', raw } }];\n}\n\n// Convertir fecha DD/MM/YYYY a YYYY-MM-DD para Google Calendar\nconst [d, m, y] = citaData.fecha.split('/');\nconst fechaISO = `${y}-${m.padStart(2,'0')}-${d.padStart(2,'0')}`;\nconst [hh, mm] = citaData.hora.split(':');\nconst startISO = `${fechaISO}T${hh.padStart(2,'0')}:${mm.padStart(2,'0')}:00`;\nconst endDate = new Date(`${fechaISO}T${startISO.split('T')[1]}`);\nendDate.setMinutes(endDate.getMinutes() + 60); // 1 hora de duración\nconst endISO = endDate.toISOString().slice(0,19);\n\nreturn [{\n  json: {\n    ...citaData,\n    fechaISO,\n    startISO,\n    endISO,\n    phone: items[0].json.phone,\n    contactName: items[0].json.contactName,\n    timestamp: items[0].json.timestamp\n  }\n}];\n"
      },
      "id": "parse-cita",
      "name": "Parsear JSON de Cita",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1340, 140]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": { "__rl": true, "mode": "id", "value": "REEMPLAZA_CON_ID_DE_TU_GOOGLE_SHEET" },
        "sheetName": { "__rl": true, "mode": "name", "value": "Citas" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Fecha Registro": "={{ $json.timestamp }}",
            "Nombre":         "={{ $json.nombre }}",
            "Teléfono":       "={{ $json.phone }}",
            "Fecha Cita":     "={{ $json.fecha }}",
            "Hora Cita":      "={{ $json.hora }}",
            "Estado":         "Confirmada"
          },
          "matchingColumns": [],
          "schema": [
            { "id": "Fecha Registro", "displayName": "Fecha Registro", "type": "string" },
            { "id": "Nombre",         "displayName": "Nombre",         "type": "string" },
            { "id": "Teléfono",       "displayName": "Teléfono",       "type": "string" },
            { "id": "Fecha Cita",     "displayName": "Fecha Cita",     "type": "string" },
            { "id": "Hora Cita",      "displayName": "Hora Cita",      "type": "string" },
            { "id": "Estado",         "displayName": "Estado",         "type": "string" }
          ]
        },
        "options": {}
      },
      "id": "sheets-cita",
      "name": "Google Sheets — Guardar Cita",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1560, 140],
      "credentials": { "googleSheetsOAuth2Api": { "id": "REEMPLAZA_CON_ID_CREDENCIAL_GOOGLE", "name": "Google Sheets" } }
    },
    {
      "parameters": {
        "calendar": { "__rl": true, "mode": "id", "value": "primary" },
