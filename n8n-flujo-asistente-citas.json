          "description": "=Cita agendada desde WhatsApp Bot\\n\\nNombre: {{ $json.nombre }}\\nTeléfono: {{ $json.phone }}\\nSolicitada el: {{ $json.timestamp }}",
          "attendees": []
        }
      },
      "id": "google-calendar",
      "name": "Google Calendar — Crear Evento",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.3,
